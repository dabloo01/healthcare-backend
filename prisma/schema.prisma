generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id           Int           @id @default(autoincrement())
  name         String
  email        String?
  phone        String
  age          Int?
  gender       String?
  address      String?
  createdAt    DateTime      @default(now())
  appointments Appointment[]
  bills        Bill[]
  prescriptions Prescription[]
  labReports    LabReport[]
}

model Doctor {
  id              Int           @id @default(autoincrement())
  name            String
  specialty       String
  phone           String
  email           String?
  consultationFee Float         @default(500)
  createdAt       DateTime      @default(now())
  appointments    Appointment[]
  prescriptions   Prescription[]
}

model Appointment {
  id              Int      @id @default(autoincrement())
  appointmentDate DateTime
  status          String   @default("Scheduled") // Status: Scheduled, Completed, Cancelled
  reason          String?
  patientId       Int
  doctorId        Int
  createdAt       DateTime @default(now())

  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor       Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  prescription Prescription?
}

model Prescription {
  id            Int      @id @default(autoincrement())
  medications   String   // JSON string or long text: "Aspirin 500mg, Paracetamol"
  instructions  String?
  date          DateTime @default(now())
  appointmentId Int      @unique
  patientId     Int
  doctorId      Int

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model LabReport {
  id          Int      @id @default(autoincrement())
  testName    String
  result      String
  status      String   @default("Completed") // Pending, Completed
  date        DateTime @default(now())
  patientId   Int

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Inventory {
  id          Int      @id @default(autoincrement())
  itemName    String
  category    String   // Medicine, Equipment, Consumable
  stock       Int
  unit        String   // Tabs, Bottles, Pieces
  expiryDate  DateTime?
  price       Float
  updatedAt   DateTime @updatedAt
}

model Bill {
  id          Int      @id @default(autoincrement())
  amount      Float
  status      String   @default("Unpaid") // Status: Paid, Unpaid
  date        DateTime @default(now())
  description String?
  patientId   Int

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model User {
  id              Int       @id @default(autoincrement())
  name            String
  role            String    @default("Patient") // Admin, Doctor, Patient, Receptionist
  email           String?
  phone           String    @unique
  password        String
  resetOtp        String?
  resetOtpExpiry  DateTime?
  createdAt       DateTime  @default(now())
}

